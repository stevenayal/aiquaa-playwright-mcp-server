{
  "name": "aiquaa-playwright-mcp-server",
  "version": "0.1.0",
  "description": "MCP server that generates AIQUAA BDD and Playwright artifacts with business-rule traceability.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "playwright",
    "playwright-bdd",
    "gherkin",
    "testing",
    "aiquaa"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevenayal/aiquaa-playwright-mcp-server.git"
  },
  "homepage": "https://github.com/stevenayal/aiquaa-playwright-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/stevenayal/aiquaa-playwright-mcp-server/issues"
  },
  "type": "module",
  "bin": {
    "aiquaa-playwright-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./rule-reporter": "./dist/extensions/rule-reporter.js",
    "./rule-tags": "./dist/extensions/rule-tags.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "examples",
    "README.md",
    "evaluation.xml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "npm run build && node --watch dist/index.js",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/services/pdf-text-validator.test.js dist/services/scenario-mapper.test.js dist/services/coverage-report.test.js dist/services/playwright-generator.test.js dist/services/context-integrations.test.js dist/server.test.js",
    "check": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "4.17.25",
    "@types/node": "22.19.19",
    "typescript": "5.9.3",
    "yaml": "2.9.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.52.0",
    "playwright-bdd": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "playwright-bdd": {
      "optional": true
    }
  },
  "overrides": {
    "iconv-lite": "0.7.2",
    "range-parser": "1.2.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
